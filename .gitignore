# Ignore local datasets and generated artifacts under data/
/data/**
!/data/**/
!/data/**/.gitkeep
!/data/DATASET_SOURCES.md

# Ignore generated experiment outputs/checkpoints
/results/**
!/results/**/
!/results/**/.gitkeep
/models/**
!/models/**/
!/models/**/.gitkeep

# Ignore local tooling/state folders
/.qodo/

# Ignore paper workspace outputs and side files by default,
# but keep the manuscript sources and results-section figures.
/paper/**
!/paper/main.tex
!/paper/references.bib
!/paper/figures/
!/paper/figures/results_section/
!/paper/figures/results_section/**

# Ignore ebook PDFs and related local reference material.
/ebooks/**

# Ignore Python bytecode caches
__pycache__/
*.py[cod]
